{
	"$schema": "https://schemas.wp.org/wp/7.0/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultGradients": false,
			"defaultPalette": false,
			"gradients": [
				{
					"gradient": "linear-gradient(105deg, #2FE6A0 0%, #22D3EE 55%, #6366F1 100%)",
					"name": "Flare",
					"slug": "flare"
				}
			],
			"palette": [
				{
					"color": "#07080A",
					"name": "Background",
					"slug": "bg"
				},
				{
					"color": "#0C0F14",
					"name": "Surface",
					"slug": "bg-2"
				},
				{
					"color": "#EEF1F4",
					"name": "Text",
					"slug": "text"
				},
				{
					"color": "#8A919C",
					"name": "Muted",
					"slug": "muted"
				},
				{
					"color": "#2FE6A0",
					"name": "Emerald",
					"slug": "amber"
				},
				{
					"color": "#22D3EE",
					"name": "Cyan",
					"slug": "pink"
				},
				{
					"color": "#6366F1",
					"name": "Indigo",
					"slug": "violet"
				}
			]
		},
		"layout": {
			"contentSize": "760px",
			"wideSize": "1280px"
		},
		"spacing": {
			"spacingScale": {
				"theme": {
					"steps": 0
				}
			},
			"spacingSizes": [
				{
					"name": "Small",
					"size": "1.5rem",
					"slug": "30"
				},
				{
					"name": "Medium",
					"size": "3rem",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "6rem",
					"slug": "70"
				}
			],
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "'Fraunces', serif",
					"name": "Fraunces",
					"slug": "display"
				},
				{
					"fontFamily": "'Space Grotesk', sans-serif",
					"name": "Space Grotesk",
					"slug": "body"
				}
			],
			"fontSizes": [
				{
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"name": "Medium",
					"size": "1.0625rem",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "1.25rem",
					"slug": "large"
				},
				{
					"name": "Extra Large",
					"size": "2rem",
					"slug": "x-large"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--bg)",
			"text": "var(--wp--preset--color--text)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "400"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "400"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display)",
					"fontWeight": "400"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--amber)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--text)"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "1.0625rem",
			"lineHeight": "1.6"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	]
}